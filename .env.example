# Anki Atlas Configuration
# Copy to .env and fill in secrets

# --- Infrastructure (docker compose up -d) ---

# Database
ANKIATLAS_POSTGRES_URL=postgresql://ankiatlas:ankiatlas@localhost:5432/ankiatlas

# Vector store
ANKIATLAS_QDRANT_URL=http://localhost:6333
ANKIATLAS_QDRANT_QUANTIZATION=scalar
ANKIATLAS_QDRANT_ON_DISK=false

# Job queue (Redis)
ANKIATLAS_REDIS_URL=redis://localhost:6379/0
ANKIATLAS_JOB_QUEUE_NAME=ankiatlas_jobs
ANKIATLAS_JOB_RESULT_TTL_SECONDS=86400
ANKIATLAS_JOB_MAX_RETRIES=3

# --- Embeddings: Gemini Embedding 2 ---
# Docs: https://ai.google.dev/gemini-api/docs/embeddings
ANKIATLAS_EMBEDDING_PROVIDER=google
ANKIATLAS_EMBEDDING_MODEL=gemini-embedding-2-preview
ANKIATLAS_EMBEDDING_DIMENSION=3072

# Google API key (required for google provider)
# Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# --- Reranking (optional) ---
ANKIATLAS_RERANK_ENABLED=false
ANKIATLAS_RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
ANKIATLAS_RERANK_TOP_N=50
ANKIATLAS_RERANK_BATCH_SIZE=32

# --- Anki source ---
# macOS default path shown; adjust for your profile
ANKIATLAS_ANKI_COLLECTION_PATH=~/Library/Application Support/Anki2/User 1/collection.anki2
ANKIATLAS_ANKI_MEDIA_ROOT=~/Library/Application Support/Anki2/User 1/collection.media

# --- API server ---
ANKIATLAS_API_HOST=0.0.0.0
ANKIATLAS_API_PORT=8000
ANKIATLAS_API_KEY=
ANKIATLAS_DEBUG=false
